{
  "name": "eslint-config-tjw-base",
  "type": "module",
  "version": "5.0.0",
  "main": "index.js",
  "description": "The Jared Wilcurt's base linting rules",
  "scripts": {
    "lint": "eslint manual-testing.js index.js",
    "debug": "node --inspect-brk ./node_modules/eslint/bin/eslint.js manual-testing.js",
    "proto": "proto pin node latest --resolve --tool-native && proto pin npm latest --resolve --tool-native && npm i"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "globals": "^17"
  },
  "peerDependencies": {
    "@stylistic/eslint-plugin": "^4 || ^5",
    "eslint": "^10"
  },
  "author": "The Jared Wilcurt",
  "keywords": [
    "tjw",
    "eslint",
    "lint"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tjw-lint/eslint-config-tjw-base.git"
  },
  "homepage": "https://github.com/tjw-lint/eslint-config-tjw-base#readme",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tjw-lint/eslint-config-tjw-base/issues"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "25.9.0"
    },
    "packageManager": {
      "name": "npm",
      "version": "11.12.1"
    }
  }
}
